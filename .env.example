# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_org_id_here

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Aegis Configuration
AEGIS_DB_PATH=./aegis.db
AEGIS_LOG_LEVEL=INFO
AEGIS_CONFIG_PATH=./aegis.yaml

# Budget Limits (USD)
AEGIS_DAILY_BUDGET_LIMIT=100.00
AEGIS_MONTHLY_BUDGET_LIMIT=3000.00

# Feature Flags
AEGIS_ENABLE_COST_TRACKING=true
AEGIS_ENABLE_REGRESSION_DETECTION=true
AEGIS_MOCK_MODE=false
